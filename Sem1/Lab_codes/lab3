/*
 C++ solution for Lab #3 task 24 (Russian -> English transliteration)

 - Reads a text file (expects UTF-8 encoding) and produces an ASCII transliteration
   of all Cyrillic characters into Latin (common internet-style transliteration).
 - Preserves punctuation, spaces, digits, and ASCII characters.
 - Uppercase Cyrillic letters produce transliterated words with an initial capital
   letter (e.g. "Пример" -> "Primer").
 - If your input file is in Windows-1251 (CP1251), convert it to UTF-8 first
   (e.g., in Notepad++: Encoding -> Convert to UTF-8) or adapt the code.

 Compile:
   g++ -std=c++17 lab3_task24_transliteration.cpp -O2 -o translit

 Usage:
   ./translit input.txt output.txt
   If output file is omitted, program prints to stdout.

 Mapping choices (common):
  а->a б->b в->v г->g д->d е->e ё->yo ж->zh з->z и->i й->y
  к->k л->l м->m н->n о->o п->p р->r с->s т->t у->u ф->f х->kh ц->ts
  ч->ch ш->sh щ->shch ъ->(empty) ы->y ь->(empty) э->e ю->yu я->ya

 This code contains a simple UTF-8 decoder/encoder and a mapping table.
*/

#include <bits/stdc++.h>
using namespace std;

// Decode UTF-8 to Unicode codepoints
static vector<uint32_t> utf8_to_codepoints(const string &s) {
    vector<uint32_t> out;
    size_t i = 0;
    while (i < s.size()) {
        unsigned char c = s[i];
        uint32_t code = 0;
        size_t extra = 0;
        if (c < 0x80) { code = c; extra = 0; }
        else if ((c & 0xE0) == 0xC0) { code = c & 0x1F; extra = 1; }
        else if ((c & 0xF0) == 0xE0) { code = c & 0x0F; extra = 2; }
        else if ((c & 0xF8) == 0xF0) { code = c & 0x07; extra = 3; }
        else { // invalid leading byte -- skip
            ++i; continue;
        }
        if (i + extra >= s.size()) break; // truncated
        for (size_t j = 1; j <= extra; ++j) {
            unsigned char cc = s[i + j];
            if ((cc & 0xC0) != 0x80) { /* invalid continuation */ }
            code = (code << 6) | (cc & 0x3F);
        }
        out.push_back(code);
        i += 1 + extra;
    }
    return out;
}

// Encode a single Unicode codepoint back to UTF-8
static string codepoint_to_utf8(uint32_t cp) {
    string res;
    if (cp <= 0x7F) res.push_back((char)cp);
    else if (cp <= 0x7FF) {
        res.push_back((char)(0xC0 | ((cp >> 6) & 0x1F)));
        res.push_back((char)(0x80 | (cp & 0x3F)));
    } else if (cp <= 0xFFFF) {
        res.push_back((char)(0xE0 | ((cp >> 12) & 0x0F)));
        res.push_back((char)(0x80 | ((cp >> 6) & 0x3F)));
        res.push_back((char)(0x80 | (cp & 0x3F)));
    } else {
        res.push_back((char)(0xF0 | ((cp >> 18) & 0x07)));
        res.push_back((char)(0x80 | ((cp >> 12) & 0x3F)));
        res.push_back((char)(0x80 | ((cp >> 6) & 0x3F)));
        res.push_back((char)(0x80 | (cp & 0x3F)));
    }
    return res;
}

int main(int argc, char** argv) {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    if (argc < 2) {
        cerr << "Usage: " << argv[0] << " input.txt [output.txt]\n";
        return 1;
    }

    string input_path = argv[1];
    string output_path;
    bool to_file = false;
    if (argc >= 3) { output_path = argv[2]; to_file = true; }

  
    ifstream ifs(input_path, ios::binary);
    if (!ifs) { cerr << "Failed to open input file: " << input_path << '\n'; return 2; }
    string input((istreambuf_iterator<char>(ifs)), istreambuf_iterator<char>());
    ifs.close();

    unordered_map<uint32_t, string> map_l;
    map_l[0x0430] = "a"; map_l[0x0431] = "b"; map_l[0x0432] = "v"; map_l[0x0433] = "g"; map_l[0x0434] = "d";
    map_l[0x0435] = "e"; map_l[0x0451] = "yo"; map_l[0x0436] = "zh"; map_l[0x0437] = "z"; map_l[0x0438] = "i";
    map_l[0x0439] = "y"; map_l[0x043A] = "k"; map_l[0x043B] = "l"; map_l[0x043C] = "m"; map_l[0x043D] = "n";
    map_l[0x043E] = "o"; map_l[0x043F] = "p"; map_l[0x0440] = "r"; map_l[0x0441] = "s"; map_l[0x0442] = "t";
    map_l[0x0443] = "u"; map_l[0x0444] = "f"; map_l[0x0445] = "kh"; map_l[0x0446] = "ts"; map_l[0x0447] = "ch";
    map_l[0x0448] = "sh"; map_l[0x0449] = "shch"; map_l[0x044A] = ""; 
    map_l[0x044B] = "y"; map_l[0x044C] = ""; 
    map_l[0x044D] = "e"; map_l[0x044E] = "yu"; map_l[0x044F] = "ya";

    auto cps = utf8_to_codepoints(input);
    string out;
    out.reserve(input.size()*2);

    for (uint32_t cp : cps) {
        if (cp <= 0x7F) {
            out.push_back((char)cp);
            continue;
        }
        if ((cp >= 0x0410 && cp <= 0x042F) || cp == 0x0401) {
            uint32_t lower = (cp == 0x0401) ? 0x0451 : (cp + 0x20);
            auto it = map_l.find(lower);
            if (it != map_l.end()) {
                string t = it->second;
                if (!t.empty()) t[0] = (char)toupper((unsigned char)t[0]);
                out += t;
                continue;
            }
        }
        if ((cp >= 0x0430 && cp <= 0x044F) || cp == 0x0451) {
            auto it = map_l.find(cp);
            if (it != map_l.end()) { out += it->second; continue; }
        }
        // For other non-ASCII characters: re-encode as UTF-8 to preserve them (or replace with '?')
        out += codepoint_to_utf8(cp);
    }

    if (to_file) {
        ofstream ofs(output_path, ios::binary);
        if (!ofs) { cerr << "Failed to open output file: " << output_path << '\n'; return 3; }
        ofs << out;
        ofs.close();
        cout << "Wrote transliterated text to " << output_path << '\n';
    } else {
        cout << out;
    }
    return 0;
}
